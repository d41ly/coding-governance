# Auto detect text files and perform LF normalization
* text=auto

# Execution-sensitive scripts must be LF (run in bash/CI). Covers the relocated tools/ kits.
*.sh text eol=lf

# The gate leg manifest is runtime-read by run-gates.sh (a stray CR would corrupt leg names/argv).
tools/gate-legs.json text eol=lf

# Git hooks are extensionless (the *.sh rule above misses them); a CRLF hook won't execute.
.githooks/pre-commit text eol=lf
.githooks/pre-push text eol=lf

# memory-tree determinism (this repo dogfoods the kit): its generated TREE.md + the two ratchet
# manifests are LF-pinned so a Windows autocrlf checkout can't spuriously fail hygiene check 9.
memory/**/TREE.md text eol=lf
memory/project/legacy-files.txt text eol=lf
memory/project/curation-debt.txt text eol=lf

# The governance template is under a STRICT byte gate — pin it (+ companions) to LF so a CRLF
# checkout can't inflate the count past the limit. (The gate also normalizes, belt-and-suspenders.)
parallel-coding-governance*.md text eol=lf
