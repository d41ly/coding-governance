# .codebase-map.conf — per-repo config for the codebase-map kit.
# Copy to your repo ROOT as `.codebase-map.conf` and edit. RESTRICTED grammar — the same file
# is sourced by bash AND parsed by map_lib.load_conf(): plain KEY=VALUE assignments; a value
# with spaces MUST be double-quoted; no inline comments after a value; no `export`. Commit it
# LF (add `.codebase-map.conf text eol=lf` to .gitattributes) — a CRLF-checked-out conf
# leaves stray carriage returns in bash-sourced values on Linux.
# The kit dir itself is copied into the repo root as `codebase-map/` (a fixed convention the
# gate template relies on — do not rename it).

# Root of the map tree, relative to the repo root. If the memory-tree kit is adopted, put it
# under that tree (e.g. memory/map) so its hygiene gate covers the prose files; otherwise
# docs/map works fine.
MAP_ROOT=memory/map

# Where adopt-codebase-map.sh copies the gate template — a path INSIDE the directory your
# project's existing test suite collects (pytest/vitest-adjacent/…). Zero CI changes by
# design: the gate rides the suite that already gates your merge bar.
GATE_FILE=tests/test_codebase_map.py

# The digest command, verbatim — consumed by the scaffolded map README and the kickoff
# manifest (humans/docs; gate remedy messages print the plain `python` spelling). Adjust if
# your launcher differs — e.g. `uv run python …` or `python3 …`.
MAP_DIFF_CMD="python codebase-map/map_diff.py"
