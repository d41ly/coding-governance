#!/usr/bin/env bash
# coding-governance pre-commit fast leg. Install once per clone: git config core.hooksPath .githooks
# Runs only the cheap staged-scoped gates so a scripts-less checkout stays green.
set -u
top=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$top" || exit 0
rc=0

# Branch guard — refuse a commit in the PRIMARY tree while parked off the default branch.
# Feature work belongs in a sibling worktree, not by stranding the primary tree on a branch
# (playbook §3). Default branch: origin/HEAD, else main; pin with GOV_DEFAULT_BRANCH. Override: --no-verify.
gd=$(git rev-parse --path-format=absolute --git-dir 2>/dev/null)
gc=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
if [ -n "$gd" ] && [ "$gd" = "$gc" ]; then          # primary tree, not a linked worktree
  def=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null); def=${def#origin/}
  def=${GOV_DEFAULT_BRANCH:-${def:-main}}
  branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)
  if [ -n "$branch" ] && [ "$branch" != "$def" ]; then
    echo "pre-commit: refusing a commit in the primary tree while on '$branch' (default: '$def')."
    echo "  Feature work belongs in a sibling worktree (playbook §3), not on the primary tree."
    rc=1
  fi
fi

# memory-tree hygiene, staged leg — only when memory/ is touched
if [ -f tools/memory-tree/check-memory-hygiene.sh ] &&
   git diff --cached --name-only --diff-filter=ACMR -- 'memory/**' | grep -q .; then
  bash tools/memory-tree/check-memory-hygiene.sh --staged || rc=1
fi

# kickoff-manifest ratchet, staged leg — only when a watched file is staged
if [ -f skills/session-kickoff/manifest-check.sh ]; then
  bash skills/session-kickoff/manifest-check.sh --staged || rc=1
fi

# template size — only when the template is staged
if [ -f tools/check-template-size.sh ] &&
   git diff --cached --name-only -- parallel-coding-governance.template.md | grep -q .; then
  bash tools/check-template-size.sh || rc=1
fi

[ "$rc" = 0 ] || echo "pre-commit: a gate failed — fix or 'git commit --no-verify' to override deliberately."
exit "$rc"
